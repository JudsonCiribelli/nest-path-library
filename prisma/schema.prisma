generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  phone     String?  @unique
  role      Role     @default(CLIENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  loans   Loan[] // Histórico de empréstimos do usuário
  reviews Review[] // Avaliações que o usuário fez

  @@map("users")
}

model Author {
  id        String    @id @default(uuid())
  name      String
  bio       String?
  birthDate DateTime?

  books   Book[] // Um autor tem muitos livros
  reviews Review[] // Avaliações recebidas pelo autor (opcional, ou nos livros)

  @@map("authors")
}

model Category {
  id   String @id @default(uuid())
  name String @unique // Ex: Ficção, Científico, Romance

  books Book[]

  @@map("categories")
}

model Book {
  id          String     @id @default(uuid())
  title       String
  description String?
  pages       Int
  year        Int
  status      BookStatus @default(AVAILABLE)

  authorId String
  author   Author @relation(fields: [authorId], references: [id], onDelete: Cascade)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  loans   Loan[]
  reviews Review[]

  @@map("books")
}

model Loan {
  id         String    @id @default(uuid())
  loanDate   DateTime  @default(now())
  returnDate DateTime?
  dueDate    DateTime

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  bookId String
  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@map("loans")
}

model Review {
  id        String   @id @default(uuid())
  stars     Int
  comment   String?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  bookId String?
  book   Book?   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  authorId String?
  author   Author? @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

enum Role {
  ADMIN
  CLIENT
}

enum BookStatus {
  AVAILABLE
  BORROWED
  MAINTENANCE
}

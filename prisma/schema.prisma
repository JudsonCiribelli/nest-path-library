generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  password     String
  phone        String?    @unique
  imageProfile String?
  active       UserStatus @default(IN_USE)
  role         Role       @default(CLIENT)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  loans   Loan[]
  reviews Review[]

  @@map("users")
}

model Author {
  id        String    @id @default(uuid())
  name      String
  bio       String?
  birthDate DateTime?

  books   Book[]
  reviews Review[]

  @@map("authors")
}

model Category {
  id   String @id @default(uuid())
  name String @unique

  books Book[]

  @@map("categories")
}

model Book {
  id          String     @id @default(uuid())
  title       String
  description String?
  pages       Int
  year        Int
  bookImage   String?
  status      BookStatus @default(AVAILABLE)

  authorId String
  author   Author @relation(fields: [authorId], references: [id], onDelete: Cascade)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  loans   Loan[]
  reviews Review[]

  @@map("books")
}

model Loan {
  id         String    @id @default(uuid())
  loanDate   DateTime  @default(now())
  returnDate DateTime?
  dueDate    DateTime

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  bookId String
  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@map("loans")
}

model Review {
  id        String   @id @default(uuid())
  stars     Int
  comment   String?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  bookId String?
  book   Book?   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  authorId String?
  author   Author? @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

enum Role {
  ADMIN
  CLIENT
}

enum UserStatus {
  IN_USE
  DISABLED
}

enum BookStatus {
  AVAILABLE
  BORROWED
  MAINTENANCE
}
